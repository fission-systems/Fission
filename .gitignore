# Benchmark binaries (compiled output, built in CI)
# Track source/build inputs only; ignore everything else under benchmark/binary.
/benchmark/binary/**
!benchmark/binary/.gitkeep
!benchmark/binary/**/source/**
!benchmark/binary/**/build.sh
# Local sample corpora and scratch projects
samples/
/benchmark/binary/realworld/**
!/benchmark/binary/realworld/.gitkeep
# Local thesis working directories (but keep scripts tracked)
/thesis/
# Script run outputs (result dirs, benchmarks, temp comparison runs)
# Use ** (not trailing /) so specific files can be un-ignored below
scripts/result/**
scripts/result*/**
