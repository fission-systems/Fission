# Rust build artifacts
/target/
/target2/
/coverage/

# fission-sleigh generated/cache artifacts are build products. The runtime
# compiles native backends into target/fission-sleigh instead of checking them in.
/crates/fission-sleigh/generated/

# Native/C++ build artifacts
/build/
ghidra_decompiler/build/
ghidra_decompiler/fission_decomp
*.obj
*.lib
*.exe
*.pdb
build_log.txt
cargo_error*.txt

# Temporary files created during development
memory_loadimage.hh
memory_loadimage.cc
/putty_single.c

# Python and environment
.venv/
.opencode/
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
scripts/**/__pycache__/
scripts/**/*.pyc

# Environment files
.env
.env.local

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log

# Third-party/vendor dependencies
vendor/

# Examples and results
/examples/results/
/examples/binaries/**/*.exe_ghidra/
/examples/binaries/**/*.exe
# Keep benchmark test binaries tracked
!examples/binaries/comparison_test_x64.exe
!examples/binaries/comparison_test_x86.exe

# Benchmark binaries (compiled output, built in CI)
# Track source/build inputs only; ignore everything else under benchmark/binary.
/benchmark/binary/**
!benchmark/binary/.gitkeep
!benchmark/binary/**/source/**
!benchmark/binary/**/build.sh

# Local sample corpora and scratch projects
samples/
/benchmark/binary/realworld/**
!/benchmark/binary/realworld/.gitkeep

# Local thesis working directories (but keep scripts tracked)
/thesis/

# Script run outputs (result dirs, benchmarks, temp comparison runs)
# Use ** (not trailing /) so specific files can be un-ignored below
scripts/result/**
scripts/result*/**
# Keep committed baselines for regression checks
!scripts/result/baseline_summary.json
!scripts/result/baseline_x86_summary.json
scripts/out/

# Python build artifacts in scripts (keep source files tracked)
scripts/**/__pycache__/
scripts/**/*.pyc

# Backup/cache artifacts
*.backup
*.cache/
ghidra_decompiler/.cache/

# Benchmark results (criterion output and run artifacts)
benchmark_results/
**/benchmark_results/
/benchmark/results/
/benchmark/history/timeline.jsonl
/benchmark/history/main_latest.json

# Local benchmark/decomp artifacts
/benchmark/artifacts/**
!/benchmark/artifacts/.gitkeep

# Keep benchmark documentation and scripts tracked
!benchmark/BENCHMARK_GUIDE.md
!benchmark/IMPLEMENTATION_SUMMARY.md
!/scripts/benchmark/

# Private product/API layer
/crates/fission-ai/

# Local benchmark scratch file
/test_bench.json

# Local agent/tooling and benchmark workspace state
/.cursor/
/.claude/
/.agent/
/.sisyphus/
/.venv-bench/
