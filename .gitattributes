# ─── Line-ending normalization ────────────────────────────────────────────────
*.rs    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.c     text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.go    text eol=lf

# ─── Binary file markers ──────────────────────────────────────────────────────
*.exe   binary
*.dll   binary
*.ico   binary
*.icns  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
