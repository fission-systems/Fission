# ─── Git LFS ──────────────────────────────────────────────────────────────────
# Large binary/data resources tracked with Git LFS.
# Goal: `git clone` delivers only Rust source + text files (~lightweight).
# To download LFS assets: `git lfs pull` or selectively:
#   git lfs pull --include="utils/signatures/**"
#
# Adopted: 2026-06-30

# Function signature databases (482 MB) — FID/FIDB/type info/patterns
utils/signatures/**            filter=lfs diff=lfs merge=lfs -text

# Ghidra data files (28 MB)
utils/ghidra-data/**           filter=lfs diff=lfs merge=lfs -text

# Compiled Sleigh specs (.sla binaries, 11 MB) — text .sinc/.slaspec stay in git
utils/sleigh-specs/compiled/** filter=lfs diff=lfs merge=lfs -text

# Compiled test binaries in benchmark/binary (source files stay in git)
benchmark/binary/**/*.exe      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.dll      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.so       filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.elf      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.o        filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.dat      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.bak      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.prp      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.gbf      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.gpr      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.sys      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.jar      filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.macho    filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.xz       filter=lfs diff=lfs merge=lfs -text
benchmark/binary/**/*.plist    filter=lfs diff=lfs merge=lfs -text

# ─── GitHub Linguist overrides ────────────────────────────────────────────────
utils/ghidra-data/**/*.exports   linguist-generated=true
utils/ghidra-data/**/*.gdt       linguist-generated=true
utils/sleigh-specs/**            linguist-language=Sleigh
utils/signatures/die/**/*.js     linguist-vendored=true
utils/signatures/die/**/*.lua    linguist-vendored=true
benchmark/binary/**/source/**    linguist-generated=true

# ─── Line-ending normalization ────────────────────────────────────────────────
*.rs    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.c     text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.go    text eol=lf

# ─── Binary file markers ──────────────────────────────────────────────────────
*.exe   binary
*.dll   binary
*.ico   binary
*.icns  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
